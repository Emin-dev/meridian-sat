# ============================================================
#  SAT Tutor — Environment Variables
#  Copy this file to ".env.local" for local dev, and add the
#  same variables in your Vercel project settings for production.
#  NEVER commit your real keys to GitHub.
# ============================================================

# --- DeepSeek V4 Pro API ---
# Get a key at https://platform.deepseek.com  (Settings -> API Keys)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# --- Supabase ---
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# The service role key is SECRET. Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin login ---
# The password you (admin) will use to log into the admin dashboard.
ADMIN_PASSWORD=change-this-to-a-strong-password
